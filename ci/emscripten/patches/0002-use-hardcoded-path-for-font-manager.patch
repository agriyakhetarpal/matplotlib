From cd0ce4fbdf53e178f9cd89c3ff375ba783d94c62 Mon Sep 17 00:00:00 2001
From: Agriya Khetarpal <74401230+agriyakhetarpal@users.noreply.github.com>
Date: Fri, 8 Mar 2024 18:41:53 +0530
Subject: [PATCH] Use hard-coded path to fontlist.json

This patch is attributed to
https://github.com/pyodide/pyodide/blob/ff8d6daaeb9fd8de41ca4db7a049e2bb31cbde9c/packages/matplotlib/patches/0003-hardcoded-font-cache.patch
where the font manager will use a local path to get a fontlist.json
schema file that is accessible through the Pyodide interpreter.
---
 lib/matplotlib/font_manager.py | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/lib/matplotlib/font_manager.py b/lib/matplotlib/font_manager.py
index 73da3c418d..7617735c56 100644
--- a/lib/matplotlib/font_manager.py
+++ b/lib/matplotlib/font_manager.py
@@ -1565,8 +1565,7 @@ def get_font(font_filepaths, hinting_factor=None):


 def _load_fontmanager(*, try_read_cache=True):
-    fm_path = Path(
-        mpl.get_cachedir(), f"fontlist-v{FontManager.__version__}.json")
+    fm_path = Path(__file__).parent.joinpath("fontlist.json")
     if try_read_cache:
         try:
             fm = json_load(fm_path)
--
